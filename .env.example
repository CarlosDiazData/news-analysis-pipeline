# NewsAPI Configuration
NEWS_API_KEY="YOUR_API_KEY_HERE"
# NEWS_API_COUNTRY="us"        # Default: us — two-letter ISO 3166-1 country code
# NEWS_API_TOPIC="technology"  # Default: none — NewsAPI category param (business, entertainment, general, health, science, sports, technology)

# Airflow Core
AIRFLOW_FERNET_KEY="YOUR_GENERATED_FERNET_KEY_HERE"
AIRFLOW_EMAIL=admin@example.com
AIRFLOW_PASSWORD=admin

# PostgreSQL Configuration
POSTGRES_USER=airflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=airflow_db

# pgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Web Scraping Configuration
USER_AGENT="NewsETL/1.0 (news-analysis-pipeline)"
MAX_SCRAPE_WORKERS=4
